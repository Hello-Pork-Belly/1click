<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.1click.handoff</string>

    <key>StartInterval</key>
    <integer>3600</integer>

    <key>RunAtLoad</key>
    <true/>

    <key>WorkingDirectory</key>
    <string>/Users/freeman/Documents/1click-exec/1click</string>

    <key>ProgramArguments</key>
    <array>
      <string>/bin/bash</string>
      <string>-lc</string>
      <string>cd "/Users/freeman/Documents/1click-exec/1click" &amp;&amp; MODE="routine" REPO="Hello-Pork-Belly/1click" ./scripts/handoff_capture.sh --auto-pr</string>
    </array>

    <key>StandardOutPath</key>
    <string>/Users/freeman/Library/Logs/1click-handoff.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/freeman/Library/Logs/1click-handoff.log</string>

    <key>EnvironmentVariables</key>
    <dict>
      <key>PATH</key>
      <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin</string>
    </dict>
  </dict>
</plist>
