hz_print_version() {
  if [ -r "${REPO_ROOT}/VERSION" ]; then
    tr -d '\n' < "${REPO_ROOT}/VERSION"
    printf '\n'
  else
    printf '0.0.0\n'
  fi
}

hz_usage() {
  cat <<'USAGE'
Usage:
  ./bin/hz --help
  ./bin/hz --version
  ./bin/hz check-env
  ./bin/hz completion bash
  ./bin/hz completion zsh
  ./bin/hz lomp-hub install --inventory <file> [--dry-run]
  ./bin/hz lomp-hub check --inventory <file> [--rootfs <dir>]
  ./bin/hz lomp-hub backup --inventory <file> --out <dir> [--rootfs <dir>]
  ./bin/hz lomp-hub restore --inventory <file> --from <dir> [--rootfs <dir>]
  ./bin/hz lomp-standard install --inventory <file> [--dry-run]
  ./bin/hz lomp-standard check --inventory <file> [--rootfs <dir>]
  ./bin/hz lomp-standard backup --inventory <file> --out <dir> [--rootfs <dir>]
  ./bin/hz lomp-standard restore --inventory <file> --from <dir> [--rootfs <dir>]
  ./bin/hz lnmp-standard install --inventory <file> [--dry-run]
  ./bin/hz lnmp-standard check --inventory <file> [--rootfs <dir>]
  ./bin/hz lnmp-standard backup --inventory <file> --out <dir> [--rootfs <dir>]
  ./bin/hz lnmp-standard restore --inventory <file> --from <dir> [--rootfs <dir>]
  ./bin/hz lnmp-lite install --role <host|hub> --inventory <file> [--dry-run]
  ./bin/hz lnmp-lite check --role <host|hub> --inventory <file> [--rootfs <dir>]
  ./bin/hz lnmp-lite backup --role <host|hub> --inventory <file> --out <dir> [--rootfs <dir>]
  ./bin/hz lnmp-lite restore --role <host|hub> --inventory <file> --from <dir> [--rootfs <dir>]
  ./bin/hz lomp-lite install --role <host|hub> --inventory <file> [--dry-run]
  ./bin/hz lomp-lite check --role <host|hub> --inventory <file> [--rootfs <dir>]
  ./bin/hz lomp-lite backup --role <host|hub> --inventory <file> --out <dir> [--rootfs <dir>]
  ./bin/hz lomp-lite restore --role <host|hub> --inventory <file> --from <dir> [--rootfs <dir>]
  ./bin/hz report html --input <path/to/log.jsonl> --output <path/to/report.html>
  ./bin/hz secret encrypt
  ./bin/hz secret decrypt

Notes:
  - completion bash|zsh prints static completion scripts to stdout.
  - lomp-hub is the bounded shared Hub MVP surface for MariaDB, Redis, and hub-main.
  - lomp-standard is the bounded single-node LOMP Standard MVP surface.
  - lnmp-standard is the bounded single-node LNMP Standard MVP surface.
  - lnmp-lite is the bounded two-node LNMP Lite MVP surface.
  - lomp-lite is the bounded two-node LOMP Lite MVP surface.
  - report html also accepts legacy forms: --latest, positional input, and --out.
  - secret encrypt/decrypt read from stdin by default.
  - other existing hz commands continue through the legacy dispatcher.
USAGE
}

hz_report_html_usage() {
  cat <<'USAGE'
Usage:
  ./bin/hz report html --input <path/to/log.jsonl> --output <path/to/report.html>
  ./bin/hz report html --latest [--output <path/to/report.html>]
  ./bin/hz report html <path/to/log.jsonl> [--out <path/to/report.html>]
USAGE
}

