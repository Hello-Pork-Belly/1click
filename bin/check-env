#!/bin/sh

ROOT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"

# shellcheck source=lib/common.sh
. "$ROOT_DIR/lib/common.sh"

# shellcheck source=lib/log.sh
. "$ROOT_DIR/lib/log.sh"

# shellcheck source=lib/check_env.sh
. "$ROOT_DIR/lib/check_env.sh"

if [ $# -gt 0 ]; then
  log_error "check-env does not accept positional arguments"
  hz_usage
  exit "$HZ_EXIT_EXPECTED_FAIL"
fi

: "${HZ_DRY_RUN:=0}"
case "$HZ_DRY_RUN" in
  0|1|2)
    ;;
  *)
    log_error "invalid HZ_DRY_RUN value: $HZ_DRY_RUN (expected 0|1|2)"
    exit "$HZ_EXIT_EXPECTED_FAIL"
    ;;
esac

check_env
rc=$?
if [ "$rc" -eq "$HZ_EXIT_OK" ]; then
  log_info "environment validation passed"
  exit "$HZ_EXIT_OK"
fi

if [ "$rc" -eq "$HZ_EXIT_EXPECTED_FAIL" ]; then
  exit "$HZ_EXIT_EXPECTED_FAIL"
fi

log_error "environment validation failed due to execution error"
exit "$HZ_EXIT_EXEC_FAIL"
